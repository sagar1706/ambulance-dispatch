# ─────────────────────────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production | test

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL via Prisma)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
# Example: postgresql://ambulance_user:mypassword@localhost:5432/ambulance_system

# ─────────────────────────────────────────────
# JWT AUTH
# ─────────────────────────────────────────────
JWT_SECRET="replace_this_with_a_random_32_char_min_string"
JWT_EXPIRES_IN="1d"           # 1d | 7d | 24h

# ─────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────
BCRYPT_ROUNDS=12              # 10-14 recommended (higher = slower = safer)

# ─────────────────────────────────────────────
# CORS — set to your frontend URL in production
# ─────────────────────────────────────────────
CLIENT_URL="http://localhost:3000"
# Production example: CLIENT_URL="https://yourfrontend.com"

# ─────────────────────────────────────────────────────────────────
# RATE LIMITING
#
# Development: set high so you don't get blocked while testing
# Production:  set low for real security
#
# Window values are in milliseconds:
#   900000  = 15 minutes (15 * 60 * 1000)
#   3600000 = 1 hour     (60 * 60 * 1000)
# ─────────────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000

REGISTER_RATE_LIMIT_MAX=20
REGISTER_RATE_LIMIT_WINDOW_MS=3600000

RESET_RATE_LIMIT_MAX=5
RESET_RATE_LIMIT_WINDOW_MS=3600000

GLOBAL_RATE_LIMIT_MAX=200
GLOBAL_RATE_LIMIT_WINDOW_MS=900000

# ─────────────────────────────────────────────
# REQUEST SIZE LIMITS
# Prevents payload flood attacks (e.g. 500MB POST body crash)
# ─────────────────────────────────────────────
JSON_BODY_LIMIT=10kb
URL_BODY_LIMIT=50kb

# ─────────────────────────────────────────────
# LOGGING
# true  → write HTTP logs to ./logs/access.log and ./logs/error.log
# false → log to console only (easier for development)
# ─────────────────────────────────────────────
LOG_TO_FILE=false

# ─────────────────────────────────────────────
# SMTP — EMAIL SENDING (for password reset)
# Leave SMTP_HOST blank to use console logging in development
# (reset link will print to server terminal instead of email)
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=your_app_password   ← use App Password, not account password
# ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=AmbulanceDispatch <noreply@ambulance.com>

# ─────────────────────────────────────────────
# DATABASE CONNECTION POOL
# DB_POOL_SIZE: max simultaneous DB connections per server instance
# DB_POOL_TIMEOUT: seconds to wait for free connection before error
# ─────────────────────────────────────────────
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=30
